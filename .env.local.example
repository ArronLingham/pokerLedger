# Supabase — copy to .env.local and fill in from your project.
# Get these from the Supabase dashboard: "Connect" button (top bar) → App Frameworks,
# or Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Current Supabase key format (starts with sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# If your project still uses the legacy key instead, you can use this name
# instead of the one above (the app accepts either):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
